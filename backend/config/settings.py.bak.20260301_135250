"""Configuration and Settings - DIBS AI v2.0"""
import os
from pathlib import Path
from pydantic_settings import BaseSettings
from typing import Optional

class Settings(BaseSettings):
    # ===== BASE PATHS =====
    # Project root (directory where this file is located: backend/config/)
    PROJECT_ROOT: Path = Path(__file__).parent.parent.parent
    BACKEND_DIR: Path = PROJECT_ROOT / "backend"
    
    # Data directories (will be created if not exist)
    DATA_DIR: Path = PROJECT_ROOT / "data"
    UPLOADS_DIR: Path = PROJECT_ROOT / "uploads"
    VIDEOS_DIR: Path = PROJECT_ROOT / "videos"
    
    # ===== DATABASE =====
    # Main database (will be in data directory)
    DB_PATH: Path = DATA_DIR / "dibs.db"
    
    # ===== SERVER =====
    HOST: str = "0.0.0.0"
    PORT: int = 8081
    PUBLIC_URL: str = "http://94.100.26.128"  # IP server Anda
    
    # ===== NVIDIA AI =====
    NVIDIA_API_KEY: str = ""
    NVIDIA_MODEL: str = "nvidia/nemotron-3-nano-30b-a3b"
    NVIDIA_MAX_TOKENS: int = 16384
    NVIDIA_TEMPERATURE: float = 1.0
    USE_NVIDIA: bool = False
    
    # ===== OLLAMA (Local AI) =====
    OLLAMA_URL: str = "http://127.0.0.1:11434"
    OLLAMA_MODEL: str = "llama3.2:3b"
    OLLAMA_FALLBACK_MODEL: str = "llama3.2:1b"
    OLLAMA_TIMEOUT: int = 180
    
    # ===== API KEYS =====
    SERPER_API_KEY: str = ""
    GEMINI_API_KEY: str = ""
    
    # ===== SECURITY =====
    JWT_SECRET_KEY: str = "dibs-secret-key-change-in-production"
    JWT_ALGORITHM: str = "HS256"
    
    # ===== FEATURE FLAGS =====
    ENABLE_VIDEO_GENERATION: bool = True
    ENABLE_REMINDERS: bool = True
    
    class Config:
        env_file = ".env"
        env_file_encoding = "utf-8"
        case_sensitive = False
        extra = "ignore"  # Ignore extra env vars

    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        
        # Create necessary directories
        self.DATA_DIR.mkdir(parents=True, exist_ok=True)
        self.UPLOADS_DIR.mkdir(parents=True, exist_ok=True)
        self.VIDEOS_DIR.mkdir(parents=True, exist_ok=True)
        
        print(f"📁 Project Root: {self.PROJECT_ROOT}")
        print(f"📁 Database: {self.DB_PATH}")
        print(f"📁 Uploads: {self.UPLOADS_DIR}")
        print(f"📁 Videos: {self.VIDEOS_DIR}")

# Global settings instance
settings = Settings()

# For backward compatibility with existing code
# Keep old variable names but point to new settings
db_path = str(settings.DB_PATH)
ollama_url = settings.OLLAMA_URL
ai_model = settings.OLLAMA_MODEL
nvidia_api_key = settings.NVIDIA_API_KEY
use_nvidia = settings.USE_NVIDIA
host = settings.HOST
port = settings.PORT
jwt_secret_key = settings.JWT_SECRET_KEY
